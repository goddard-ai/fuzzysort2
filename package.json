{
  "name": "fuzzysort2",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Alec Larson",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleclarson/fuzzysort2.git"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "!examples/tsconfig.json"
  ],
  "type": "module",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsdown --sourcemap --watch",
    "build": "tsdown",
    "format": "oxfmt .",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit && tsc -p test --noEmit && tsc -p examples --noEmit",
    "test": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "radashi": "^12.7.2",
    "tsdown": "^0.21.9",
    "tsnapi": "^0.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
